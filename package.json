{
  "name": "nextdestiny-battleplanner",
  "version": "3.2.0",
  "private": true,
  "description": "Team-scoped tactical strategy planning for competitive games — Discord-auth only",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @nd-battleplanner/server dev\" \"pnpm --filter @nd-battleplanner/client dev\"",
    "build": "pnpm --filter @nd-battleplanner/shared build && pnpm --filter @nd-battleplanner/server build && pnpm --filter @nd-battleplanner/client build",
    "db:generate": "pnpm --filter @nd-battleplanner/server db:generate",
    "db:migrate": "pnpm --filter @nd-battleplanner/server db:migrate",
    "db:seed": "pnpm --filter @nd-battleplanner/server db:seed",
    "db:seed:run": "pnpm --filter @nd-battleplanner/server db:seed:run",
    "db:push": "pnpm --filter @nd-battleplanner/server db:push",
    "db:studio": "pnpm --filter @nd-battleplanner/server db:studio",
    "import:maps": "pnpm --filter @nd-battleplanner/server import:maps"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "sharp"
    ],
    "allowedDeprecatedVersions": {
      "@esbuild-kit/core-utils": "3.3.2",
      "@esbuild-kit/esm-loader": "2.6.5"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2"
  }
}
