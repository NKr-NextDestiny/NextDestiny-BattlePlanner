# Database
DATABASE_URL=postgresql://battleplanner:battleplanner@localhost:5432/battleplanner

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# Public URL — used in redirects.
# In development, point to the Vite dev server (port 5173), NOT the API (port 3001).
APP_URL=http://localhost:5173

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# Discord OAuth2
# Create an application at https://discord.com/developers/applications
# Set redirect URI to: {APP_URL}/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# Discord Admin — the Discord user ID of the initial admin user
# Used by the seed script to create the first admin account
DISCORD_ADMIN_ID=

# Uploads
# UPLOAD_DIR — only set if you want a custom absolute path (default: packages/server/uploads/)
MAX_FILE_SIZE=5242880

# Client — set to your server's public URL in production
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
