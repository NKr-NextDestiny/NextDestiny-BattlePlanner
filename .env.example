# Database
# Local development: use localhost.
# Docker production stack: docker-compose injects the internal service URL automatically.
DATABASE_URL=postgresql://battleplanner:battleplanner@localhost:5432/battleplanner

# Redis
# Local development: use localhost.
# Docker production stack: docker-compose injects the internal service URL automatically.
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# Public browser URL used in OAuth redirects.
# Development: http://localhost:5173
# Docker production: e.g. http://your-server-ip or https://your-domain
APP_URL=http://localhost:5173

# JWT
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# Discord OAuth2
# Create an application at https://discord.com/developers/applications
# Redirect URI should be: {APP_URL}/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# Discord Admin
# The Discord user ID of the initial admin account created by the seed script
DISCORD_ADMIN_ID=

# Uploads
# UPLOAD_DIR only if you want a custom absolute path (default: packages/server/uploads/)
MAX_FILE_SIZE=5242880
