{
  "name": "@nd-battleplanner/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "db:generate": "tsx ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:run": "node dist/db/seed.js",
    "db:studio": "tsx ./node_modules/drizzle-kit/bin.cjs studio",
    "db:push": "tsx ./node_modules/drizzle-kit/bin.cjs push",
    "import:maps": "tsx src/scripts/import-maps.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "@nd-battleplanner/shared": "workspace:*",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
